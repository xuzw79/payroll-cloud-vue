generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PayType {
  MONTHLY
  HOURLY
}

enum UserRole {
  ADMIN
  ACCOUNTING
  VIEWER
  EMPLOYEE
}

enum SesBillingType {
  FIXED
  TIME_RANGE
  HOURLY
}

enum SesMemberSource {
  EMPLOYEE
  EXTERNAL
}

enum SesContractType {
  SALES
  PURCHASE
}

model Employee {
  id          String    @id @default(cuid())
  employeeNo  String    @unique
  name        String
  position    String?
  email       String?
  defaultDependentCount Int @default(0)
  employmentInsuranceEnrolled Boolean @default(true)
  payType     PayType   @default(MONTHLY)
  basePay     Int
  fixedOvertimeAllowance Int @default(0)
  memo        String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  payrolls    Payroll[]
  bonuses     Bonus[]
  users       AppUser[]
  sesContractMembers SesContractMember[]
  sesRevenues SesRevenue[]
  sesExpenses SesExpense[]
}

model AppUser {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  role         UserRole  @default(VIEWER)
  passwordHash String
  employeeId   String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  employee     Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([role])
  @@index([employeeId])
}

model Payroll {
  id                       String   @id @default(cuid())
  employeeId               String
  period                   String
  workDays                 Decimal  @db.Decimal(8, 2)
  workHours                Decimal  @db.Decimal(8, 2)
  overtimeHours            Decimal  @db.Decimal(8, 2)
  allowance                Int      @default(0)
  fixedOvertimeAllowance   Int      @default(0)
  fixedDeduction           Int      @default(0)
  overtimeRate             Decimal  @db.Decimal(8, 6)
  incomeTaxRate            Decimal  @db.Decimal(8, 6)
  socialInsuranceRate      Decimal  @db.Decimal(8, 6)
  healthInsuranceRate      Decimal  @db.Decimal(8, 6) @default(0.050000)
  pensionInsuranceRate     Decimal  @db.Decimal(8, 6) @default(0.100000)
  childCareSupportRate     Decimal  @db.Decimal(8, 6) @default(0.000000)
  employmentInsuranceRate  Decimal  @db.Decimal(8, 6)
  socialInsuranceEnrolled  Boolean  @default(true)
  employmentInsuranceEnrolled Boolean @default(true)
  socialInsuranceBaseAmount Int?
  regularPay               Int
  overtimePay              Int
  grossPay                 Int
  incomeTax                Int
  healthInsurance          Int      @default(0)
  pensionInsurance         Int      @default(0)
  childCareSupport         Int      @default(0)
  socialInsurance          Int
  employmentInsurance      Int
  residentTax              Int      @default(0)
  dormitoryFee             Int      @default(0)
  totalDeduction           Int
  netPay                   Int
  fiscalYear               Int?
  dependentCount           Int      @default(0)
  taxableIncome            Int?
  emailedAt                DateTime?
  note                     String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  employee                 Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, period])
  @@index([period])
}

model CompanySetting {
  id                       String   @id @default("default")
  currentFiscalYear        Int?
  fiscalClosingMonth       Int      @default(3)
  overtimeRate             Decimal  @db.Decimal(8, 6) @default(1.250000)
  incomeTaxRate            Decimal  @db.Decimal(8, 6) @default(0.030000)
  socialInsuranceRate      Decimal  @db.Decimal(8, 6) @default(0.150000)
  healthInsuranceRate      Decimal  @db.Decimal(8, 6) @default(0.050000)
  pensionInsuranceRate     Decimal  @db.Decimal(8, 6) @default(0.100000)
  childCareSupportRate     Decimal  @db.Decimal(8, 6) @default(0.000000)
  employmentInsuranceRate  Decimal  @db.Decimal(8, 6) @default(0.006000)
  invoiceCompanyName       String?
  invoicePostalCode        String?
  invoiceAddress           String?
  invoiceTel               String?
  invoiceRegistrationNo    String?
  invoiceBankName          String?
  invoiceBankBranch        String?
  invoiceBankAccount       String?
  invoiceBankHolder        String?
  updatedAt                DateTime @updatedAt
}

model FiscalRate {
  id                       String   @id @default(cuid())
  fiscalYear               Int      @unique
  overtimeRate             Decimal  @db.Decimal(8, 6) @default(1.250000)
  incomeTaxRate            Decimal  @db.Decimal(8, 6) @default(0.030000)
  socialInsuranceRate      Decimal  @db.Decimal(8, 6) @default(0.150000)
  healthInsuranceRate      Decimal  @db.Decimal(8, 6) @default(0.050000)
  pensionInsuranceRate     Decimal  @db.Decimal(8, 6) @default(0.100000)
  childCareSupportRate     Decimal  @db.Decimal(8, 6) @default(0.000000)
  employmentInsuranceRate  Decimal  @db.Decimal(8, 6) @default(0.006000)
  memo                     String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Bonus {
  id                       String   @id @default(cuid())
  employeeId               String
  period                   String
  bonusAmount              Int      @default(0)
  incomeTaxRate            Decimal  @db.Decimal(8, 6)
  healthInsuranceRate      Decimal  @db.Decimal(8, 6)
  pensionInsuranceRate     Decimal  @db.Decimal(8, 6)
  childCareSupportRate     Decimal  @db.Decimal(8, 6) @default(0.000000)
  employmentInsuranceRate  Decimal  @db.Decimal(8, 6)
  socialInsuranceEnrolled  Boolean  @default(true)
  employmentInsuranceEnrolled Boolean @default(true)
  socialInsuranceBaseAmount Int?
  taxableIncome            Int
  incomeTax                Int
  healthInsurance          Int      @default(0)
  pensionInsurance         Int      @default(0)
  childCareSupport         Int      @default(0)
  socialInsurance          Int
  employmentInsurance      Int
  totalDeduction           Int
  netPay                   Int
  fiscalYear               Int?
  note                     String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  employee                 Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, period])
  @@index([period])
}

model IncomeTaxBracket {
  id              String   @id @default(cuid())
  fiscalYear      Int
  dependentCount  Int
  minTaxable      Int
  maxTaxable      Int?
  taxAmount       Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([fiscalYear, dependentCount, minTaxable])
}

model Customer {
  id              String   @id @default(cuid())
  name            String
  code            String?  @unique
  contactName     String?
  email           String?
  phone           String?
  postalCode      String?
  address         String?
  invoiceNumber   String?
  isSoleProprietor Boolean  @default(false)
  closingDay      Int?
  paymentSiteDays Int?
  memo            String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  sesContracts    SesContract[]
  externalMembers SesExternalMember[]
  sesInvoices     SesInvoice[]
  sesRevenues     SesRevenue[]
  sesExpenses     SesExpense[]

  @@index([name])
  @@index([isActive])
}

model SesExternalMember {
  id                String   @id @default(cuid())
  customerId        String?
  name              String
  code              String?
  email             String?
  phone             String?
  memo              String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  customer          Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  contractMembers   SesContractMember[]
  sesRevenues        SesRevenue[]
  sesExpenses        SesExpense[]

  @@index([customerId])
  @@index([name])
  @@index([isActive])
}

model SesContract {
  id              String   @id @default(cuid())
  customerId      String
  contractType    SesContractType @default(SALES)
  contractNo      String?
  title           String
  startDate       String?
  endDate         String?
  memo            String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  members         SesContractMember[]
  invoices        SesInvoice[]
  revenues        SesRevenue[]
  expenses        SesExpense[]

  @@index([customerId])
  @@index([title])
  @@index([isActive])
}

model SesContractMember {
  id                  String          @id @default(cuid())
  contractId          String
  source              SesMemberSource
  employeeId          String?
  externalMemberId    String?
  billingType         SesBillingType  @default(FIXED)
  itemDescription     String?
  unitPrice           Int             @default(0)
  lowerLimitHours     Decimal?        @db.Decimal(8, 2)
  upperLimitHours     Decimal?        @db.Decimal(8, 2)
  deductionHourlyRate Int             @default(0)
  excessHourlyRate    Int             @default(0)
  startDate           String?
  endDate             String?
  memo                String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  contract            SesContract     @relation(fields: [contractId], references: [id], onDelete: Cascade)
  employee            Employee?       @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  externalMember      SesExternalMember? @relation(fields: [externalMemberId], references: [id], onDelete: SetNull)

  @@index([contractId])
  @@index([employeeId])
  @@index([externalMemberId])
}

model SesInvoice {
  id              String   @id @default(cuid())
  customerId      String
  contractId      String?
  period          String
  invoiceNo       String?
  issueDate       String
  dueDate         String?
  title           String
  subtotal        Int      @default(0)
  taxRate         Decimal  @db.Decimal(8, 6) @default(0.100000)
  taxAmount       Int      @default(0)
  totalAmount     Int      @default(0)
  note            String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  contract        SesContract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  items           SesInvoiceItem[]

  @@index([customerId])
  @@index([contractId])
  @@index([period])
  @@index([contractId, period])
  @@index([isActive])
}

model SesInvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Decimal  @db.Decimal(10, 2) @default(1)
  unit         String   @default("式")
  unitPrice   Int      @default(0)
  amount      Int      @default(0)
  workHours   Decimal? @db.Decimal(8, 2)
  memo        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  invoice     SesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model SesRevenue {
  id                String   @id @default(cuid())
  period            String
  customerId        String?
  contractId        String?
  employeeId        String?
  externalMemberId  String?
  title             String
  amount            Int      @default(0)
  memo              String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  customer          Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  contract          SesContract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  employee          Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  externalMember    SesExternalMember? @relation(fields: [externalMemberId], references: [id], onDelete: SetNull)

  @@index([period])
  @@index([customerId])
  @@index([contractId])
  @@index([employeeId])
  @@index([externalMemberId])
  @@index([isActive])
}

model SesExpense {
  id                String   @id @default(cuid())
  period            String
  customerId        String?
  contractId        String?
  employeeId        String?
  externalMemberId  String?
  title             String
  amount            Int      @default(0)
  memo              String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  customer          Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  contract          SesContract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  employee          Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  externalMember    SesExternalMember? @relation(fields: [externalMemberId], references: [id], onDelete: SetNull)

  @@index([period])
  @@index([customerId])
  @@index([contractId])
  @@index([employeeId])
  @@index([externalMemberId])
  @@index([isActive])
}
