generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PayType {
  MONTHLY
  HOURLY
}

model Employee {
  id          String    @id @default(cuid())
  employeeNo  String    @unique
  name        String
  email       String?
  defaultDependentCount Int @default(0)
  payType     PayType   @default(MONTHLY)
  basePay     Int
  memo        String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  payrolls    Payroll[]
}

model Payroll {
  id                       String   @id @default(cuid())
  employeeId               String
  period                   String
  workDays                 Decimal  @db.Decimal(8, 2)
  workHours                Decimal  @db.Decimal(8, 2)
  overtimeHours            Decimal  @db.Decimal(8, 2)
  allowance                Int      @default(0)
  fixedDeduction           Int      @default(0)
  overtimeRate             Decimal  @db.Decimal(7, 5)
  incomeTaxRate            Decimal  @db.Decimal(7, 5)
  socialInsuranceRate      Decimal  @db.Decimal(7, 5)
  healthInsuranceRate      Decimal  @db.Decimal(7, 5) @default(0.05000)
  pensionInsuranceRate     Decimal  @db.Decimal(7, 5) @default(0.10000)
  employmentInsuranceRate  Decimal  @db.Decimal(7, 5)
  socialInsuranceEnrolled  Boolean  @default(true)
  socialInsuranceBaseAmount Int?
  regularPay               Int
  overtimePay              Int
  grossPay                 Int
  incomeTax                Int
  healthInsurance          Int      @default(0)
  pensionInsurance         Int      @default(0)
  socialInsurance          Int
  employmentInsurance      Int
  totalDeduction           Int
  netPay                   Int
  fiscalYear               Int?
  dependentCount           Int      @default(0)
  taxableIncome            Int?
  emailedAt                DateTime?
  note                     String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  employee                 Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, period])
  @@index([period])
}

model CompanySetting {
  id                       String   @id @default("default")
  currentFiscalYear        Int?
  overtimeRate             Decimal  @db.Decimal(7, 5) @default(1.25000)
  incomeTaxRate            Decimal  @db.Decimal(7, 5) @default(0.03000)
  socialInsuranceRate      Decimal  @db.Decimal(7, 5) @default(0.15000)
  healthInsuranceRate      Decimal  @db.Decimal(7, 5) @default(0.05000)
  pensionInsuranceRate     Decimal  @db.Decimal(7, 5) @default(0.10000)
  employmentInsuranceRate  Decimal  @db.Decimal(7, 5) @default(0.00600)
  updatedAt                DateTime @updatedAt
}

model FiscalRate {
  id                       String   @id @default(cuid())
  fiscalYear               Int      @unique
  overtimeRate             Decimal  @db.Decimal(7, 5) @default(1.25000)
  incomeTaxRate            Decimal  @db.Decimal(7, 5) @default(0.03000)
  socialInsuranceRate      Decimal  @db.Decimal(7, 5) @default(0.15000)
  healthInsuranceRate      Decimal  @db.Decimal(7, 5) @default(0.05000)
  pensionInsuranceRate     Decimal  @db.Decimal(7, 5) @default(0.10000)
  employmentInsuranceRate  Decimal  @db.Decimal(7, 5) @default(0.00600)
  memo                     String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model IncomeTaxBracket {
  id              String   @id @default(cuid())
  fiscalYear      Int
  dependentCount  Int
  minTaxable      Int
  maxTaxable      Int?
  taxAmount       Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([fiscalYear, dependentCount, minTaxable])
}
